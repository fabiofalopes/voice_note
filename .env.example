# Groq API Key - Get yours at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Fireworks AI API Key (optional) - Get yours at https://fireworks.ai (no CC required)
# Only needed if using --provider fireworks
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Modelos AI API Key (optional) - Get yours from Modelos AI
# Only needed if using --provider modelos
MODELOS_AI_KEY=your_modelos_ai_key_here